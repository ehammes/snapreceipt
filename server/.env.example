PORT=3001
DATABASE_URL=postgresql://username:password@localhost:5432/snapreceipt
# Generate with: openssl rand -base64 32
JWT_SECRET=your-secret-key-min-32-characters
NODE_ENV=development

# Google Vision API - use ONE of these options:
# Option 1: File path (local development)
GOOGLE_APPLICATION_CREDENTIALS=./google-vision-credentials.json
# Option 2: JSON string (Railway/production) - paste entire JSON contents
# GOOGLE_CREDENTIALS_JSON={"type":"service_account","project_id":"..."}

# Frontend URL for CORS and magic link generation
# FRONTEND_URL=https://your-app.vercel.app

# Resend (email service for magic links) - get API key at resend.com
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxx
# Optional: custom from address once you've verified a domain in Resend
# RESEND_FROM_EMAIL=SnapReceipt <noreply@yourdomain.com>
